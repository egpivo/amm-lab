# Copy to .env and fill in. Required ONLY by the on-chain data-layer /
# fetch tooling (calibration data pulls). The RL-equilibrium paper pipeline
# (make m3r-final / m4 / ladder / verify, all rl_equilibrium_* binaries,
# scripts/rl_equilibrium/) reads no environment variables and needs none of
# these.

# Uniswap subgraph / API
UNISWAP_API_KEY=

# Alchemy RPC URLs (one per chain)
ALCHEMY_ETHEREUM_URL=
ALCHEMY_BASE_URL=
ALCHEMY_ARBITRUM_URL=
ALCHEMY_POLYGON_URL=

# Dune Analytics
DUNE_API_KEY=

# Helius (Solana)
HELIUS_API_KEY=
HELIUS_RPC_URL=
